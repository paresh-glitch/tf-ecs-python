# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
terraform.tfvars
*.tfvars.json

# Ignore override files as they may contain local overrides
*.tfexport
*_override.tf
*_override.tf.json

# Include override files you do want to track if necessary
# !example_override.tf

# Include lock file as recommended by Terraform official docs
.terraform.lock.hcl
.env
